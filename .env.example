# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Etsy — register an app at https://www.etsy.com/developers/your-apps
# v3 OAuth 2.0 with PKCE; you only need the keystring (client_id)
ETSY_CLIENT_ID=
ETSY_REDIRECT_URI=http://localhost:8765/callback

# Filled in automatically after `python -m etsy_agent.cli auth`
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_TOKEN_EXPIRES_AT=
ETSY_SHOP_ID=
ETSY_USER_ID=

# Where the agent writes generated .xlsx files and mockup previews
OUTPUT_DIR=./output
